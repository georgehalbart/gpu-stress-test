{
  "manifest_version": 3,
  "name": "GPU Benchmark & Stress Test",
  "version": "1.0",
  "description": "Test your GPU performance with real-time WebGL rendering and benchmarking, all inside your browser.",
  "action": {
    "default_popup": "index.html",
    "default_title": "Open GPU Test"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "gpu-stress-test@bilalmd.com",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
